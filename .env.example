# =========================================================
# ExplorApp — Variables de entorno (ejemplo)
# Copia este archivo como `.env` y completa los valores reales.
# NO subir el archivo .env al repositorio.
# =========================================================

# --- Base de datos PostgreSQL ---
# El host coincide con el nombre del servicio en docker-compose.yml
POSTGRES_USER=admin
POSTGRES_PASSWORD=password123
POSTGRES_DB=gestion_personal
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# URL de conexión usada por los microservicios FastAPI
DATABASE_URL=postgresql://admin:password123@postgres:5432/gestion_personal

# --- Auth0 (autenticación de la app móvil) ---
AUTH0_DOMAIN=tu-dominio.auth0.com
AUTH0_AUDIENCE=https://api.explorapp
AUTH0_ALGORITHMS=RS256

# --- n8n (motor de automatización / RAG) ---
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
NODE_ENV=production

# --- Almacenamiento de fotos ---
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=2

# --- Puertos publicados al host ---
# PostgreSQL NO publica puerto al host (RNF5 — solo accesible en la red interna).
FRONTEND_PORT=5173
MS_CREACION_PORT=8001
MS_MODIFICACION_PORT=8002
MS_CONSULTA_PORT=8003
MS_BORRADO_PORT=8004
MS_LOG_PORT=8005
N8N_PUBLIC_PORT=5678
