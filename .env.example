# =========================================================
# ExplorApp — Variables de entorno (ejemplo)
# Copia este archivo como `.env` y completa los valores reales.
# NO subir el archivo .env al repositorio.
# =========================================================

# --- Base de datos PostgreSQL ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=password123
POSTGRES_DB=personasdb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://admin:password123@postgres:5432/personasdb

# --- Auth0 (autenticación de la app web y API) ---
AUTH0_DOMAIN=dev-i1aenfwhn0il1ty6.us.auth0.com
AUTH0_CLIENT_ID=iVNnme8tydK9kasEUHCvzlzOuqNEJcow
AUTH0_AUDIENCE=https://api.explorapp
AUTH0_ALGORITHMS=RS256
AUTH0_CLIENT_SECRET=tu_client_secret_de_auth0_ficticio # Requerido por la rúbrica para el backend

# --- Auth0 para el frontend Vite (crear frontend/.env con estos valores) ---
VITE_AUTH0_DOMAIN=dev-i1aenfwhn0il1ty6.us.auth0.com
VITE_AUTH0_CLIENT_ID=iVNnme8tydK9kasEUHCvzlzOuqNEJcow
VITE_AUTH0_AUDIENCE=https://api.explorapp

# --- n8n (motor de automatización / RAG) ---
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
NODE_ENV=production
N8N_BASIC_AUTH_USER=admin_ficticio                     # Requerido por la rúbrica
N8N_BASIC_AUTH_PASSWORD=password_n8n_ficticio          # Requerido por la rúbrica

# --- Inteligencia Artificial ---
LLM_API_KEY=tu_api_key_de_openai_o_gemini_aqui         # Requerido por la rúbrica

# --- Servicios Internos y Almacenamiento ---
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=2
PHOTOS_VOLUME_PATH=./data/photos                       # Requerido por la rúbrica
LOG_SERVICE_URL=http://ms-log:8005                     # Requerido por la rúbrica (apuntando a tu puerto)

# --- Puertos publicados al host ---
FRONTEND_PORT=5173
MS_CREACION_PORT=8001
MS_MODIFICACION_PORT=8002
MS_CONSULTA_PORT=8003
MS_BORRADO_PORT=8004
MS_LOG_PORT=8005
N8N_PUBLIC_PORT=5678